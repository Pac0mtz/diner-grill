# Server
PORT=8787
ADMIN_TOKEN=change-me

# Google Places (optional) — live reviews + place photos on /reviews
# Enable Places API (New) in Google Cloud, then set:
# GOOGLE_PLACES_API_KEY=AIza...

# Stripe — prefer Admin → Settings → Stripe payments (saved in DB).
# Env values are fallbacks if Settings are empty.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key (also settable in Admin Settings; VITE_ is build-time fallback)
VITE_STRIPE_PK=pk_test_...

# ---------------------------------------------------------------------------
# Kitchen printing
# Prefer Admin → Settings in the dashboard; env vars are fallbacks.
# print_method: email | agent | both  (default email = Epson mail-to-print)
# ---------------------------------------------------------------------------
PRINT_METHOD=email

# Epson Connect mail-to-print (Email Print address from Epson Connect)
PRINTER_EMAIL=yourprinter@print.epsonconnect.com

# SMTP (Gmail app password, Microsoft 365, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com

# LAN ePOS printer (only needed for print_method=agent or both;
# used by scripts/print-agent.mjs on the restaurant LAN)
PRINTER_IP=192.168.1.50
PRINTER_DEVICE_ID=local_printer

# Staff order notifications (To + CC). Same SMTP as above.
NOTIFY_EMAILS=owner@example.com
NOTIFY_EMAIL_CC=kitchen@example.com
ORDER_ALERT_SOUND=1

# Customer emails (receipt + status). Prefer Admin → Settings → Customer emails.
# CUSTOMER_EMAILS_ENABLED=1
# CUSTOMER_EMAIL_RECEIPT=1
# CUSTOMER_EMAIL_ACCEPTED=1
# CUSTOMER_EMAIL_READY=1
# CUSTOMER_EMAIL_COMPLETED=0
# CUSTOMER_EMAIL_CANCELLED=1

# Receipt template (Epson 80mm Font A ≈ 42 cols). Prefer Admin → Settings editor.
# RECEIPT_WIDTH=42
# RECEIPT_NAME=DINER GRILL
# RECEIPT_ADDRESS=1635 W Irving Park Rd, Chicago, IL 60613
# RECEIPT_PHONE=(773) 248-2030
