# Server
PORT=8787
ADMIN_TOKEN=change-me

# Stripe (server) — without these, POST /api/orders returns 503 and the
# customer UI shows the "call to order" fallback.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe publishable key (frontend, bundled by Vite)
VITE_STRIPE_PK=pk_test_...

# Receipt printer (used by scripts/print-agent.mjs on the restaurant LAN,
# and as fallback for the server-side test print)
PRINTER_IP=192.168.1.50
PRINTER_DEVICE_ID=local_printer
